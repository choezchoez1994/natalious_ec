# ===== natalious · variables de entorno =====
# Copia este archivo a .env y completa con los datos de tu proyecto Supabase.
# Settings → API en el panel de Supabase.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# ===== Chat IA (Edge Function 'chat-ia') =====
# IMPORTANTE: la clave de Groq NO va aquí ni lleva prefijo VITE_ (quedaría
# expuesta en el bundle del navegador). Se configura como SECRET del lado
# servidor en Supabase, con:
#   supabase secrets set GROQ_API_KEY=gsk_...
# Obtén la clave en https://console.groq.com/keys
